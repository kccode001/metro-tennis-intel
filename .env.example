# Database
DATABASE_URL=postgresql://localhost:5432/metro_tennis_intel

# Apify — required for IG/TikTok/Facebook scraping
# Get token at https://console.apify.com/account/integrations
APIFY_API_TOKEN=

# Google APIs
GOOGLE_PLACES_API_KEY=
YOUTUBE_API_KEY=

# Anthropic — required for sentiment analysis (Haiku) and WA agent (Sonnet)
ANTHROPIC_API_KEY=

# Discord webhook for alerts and digests
DISCORD_WEBHOOK_URL=

# WhatsApp group JID — provided by KC once the group is created
# Format: 628xxxx@g.us
WA_GROUP_JID=

# Internal API auth secret (for future API endpoints at port 5004)
INTERNAL_API_SECRET=

# Sentiment alert thresholds (defaults shown)
NEGATIVE_COMMENT_THRESHOLD=3        # ≥N negative comments in 4h → warning
NEGATIVE_COMMENT_WINDOW_HOURS=4
CRITICAL_SENTIMENT_SCORE=-0.7       # score ≤ this → critical alert
